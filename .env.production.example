# ── 데이터베이스 (MySQL / PostgreSQL) ────────────────
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=blog_user
DATABASE_PASSWORD=CHANGE_ME
DATABASE_NAME=my_blog

# PostgreSQL (Vercel/Neon/Supabase) 사용 시
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# ── 사이트 기본 정보 ─────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME=내 블로그

# ── LLM API (하나만 선택) ────────────────────────────
GEMINI_API_KEY=           # https://aistudio.google.com/app/apikey
# OPENAI_API_KEY=         # https://platform.openai.com/api-keys
# ANTHROPIC_API_KEY=      # https://console.anthropic.com/settings/keys

# ── 이미지 API (하나만 선택, 선택 사항) ──────────────
UNSPLASH_ACCESS_KEY=      # https://unsplash.com/developers
# PEXELS_API_KEY=         # https://www.pexels.com/api/

# ── 댓글 스팸 방지 (필수) ────────────────────────────
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=CHANGE_ME
HCAPTCHA_SECRET_KEY=CHANGE_ME

# ── 관리자 API 키 (자동 생성 권장) ───────────────────
ADMIN_API_KEY=CHANGE_ME

# ── 댓글 Rate Limit ───────────────────────────────────
COMMENT_RATE_LIMIT=3
RATE_LIMIT_WINDOW=60

# ── Google Analytics (선택) ───────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Google AdSense (20개 글 발행 후 신청) ────────────
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
